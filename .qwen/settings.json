{
	"theme": "Default",
	"preferredEditor": "vscode-insiders",
	"autoAccept": "false",
	"contextFileName": "QWEN.md",
	"disabledTools": [
		"web_fetch"
	],
	"mcpServers": {
		"sequential-thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"version": "0.0.1"
		},
		"memory": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"version": "0.0.1"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp",
			"version": "0.0.1"
		},
		"microsoft-docs": {
			"url": "https://learn.microsoft.com/api/mcp",
			"type": "http"
		},
		"playwright": {
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"disabled": true
		}
	},
	"inputs": []
}