{
  "name": "ai-new-workflow-app-template-build",
  "image": "ghcr.io/intel-agency/ai-new-workflow-app-template:main-latest",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "DOTNET_ROOT": "/usr/share/dotnet",
  },
  "onCreateCommand": "npm install -g @modelcontextprotocol/server-sequential-thinking @modelcontextprotocol/server-memory && cd .opencode && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-python.python",
        "oven.bun-vscode",
        "avaloniateam.vscode-avalonia",
      ],
    },
  },
  "remoteUser": "vscode",
}
